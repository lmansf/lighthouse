# fastlane lanes for Lighthouse mobile (app.lhvault). Signing is managed by
# `match`; store auth is an App Store Connect API key. NOTHING sensitive lives
# here — every credential is read from the environment / CI secrets. See
# docs/mobile-signing.md for the secret names and the one-time bootstrap.
#
# NOTE: the iOS/Android build lanes require the native projects generated by
# `tauri ios init` / `tauri android init` under `gen/` (§2.2), which must be run
# on macOS / with the Android SDK. The `certs` lane below is standalone and can
# run as soon as the match repo + API-key secrets exist.

# App Store Connect API key from env. The .p8 is passed as its (base64) content
# so no key file is ever written to disk in CI.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
    key_content: ENV.fetch("APP_STORE_CONNECT_KEY_P8"),
    is_key_content_base64: ENV.fetch("APP_STORE_CONNECT_KEY_P8_BASE64", "1") == "1",
    in_house: false,
  )
end

platform :ios do
  # One-time (and on cert rotation) bootstrap: create/refresh the Distribution
  # certificate + App Store provisioning profile for app.lhvault and store them
  # encrypted in MATCH_GIT_URL. Run this once on macOS (or a macOS CI job) after
  # the secrets are set. Safe to re-run — it reuses existing valid certs.
  lane :certs do
    key = asc_api_key
    # Only the App Store **Distribution** cert + profile are needed for
    # TestFlight / App Store builds. We deliberately do NOT create a
    # `development` cert here: it's for local on-device debug builds we don't do
    # in CI, and Apple caps an account at 2 Development certs — hitting that cap
    # would fail the whole bootstrap even though distribution signing is fine.
    # Use the separate `ios dev_certs` lane below only if you need debug builds.
    match(type: "appstore", api_key: key, readonly: false)
  end

  # Optional: development signing for local on-device debug builds. Kept out of
  # `certs` so a full Development-certificate slot (Apple allows 2) can't block
  # the App Store bootstrap. Run manually only when you actually need it.
  lane :dev_certs do
    match(type: "development", api_key: asc_api_key, readonly: false)
  end

  # Build the signed App Store .ipa. IMPORTANT: bare xcodebuild/gym CANNOT
  # build this project — the "Build Rust Code" phase's `tauri ios xcode-script`
  # panics without the outer `tauri ios build` process (it connects back to it
  # via a server-addr file in TMPDIR; probe run 29708159958 proved this). So
  # the Tauri CLI drives the archive/export, on its supported CI path:
  #   - match (readonly) installs the Apple Distribution cert into the CI
  #     keychain (setup_ci) — the signing identity;
  #   - the ASC API key goes to xcodebuild via APPLE_API_KEY/ISSUER/KEY_PATH +
  #     -allowProvisioningUpdates (Tauri wires this), so AUTOMATIC signing
  #     resolves profiles headlessly. No manual-signing pbxproj surgery.
  # Prereqs on the runner: npm ci + static UI export + rust aarch64-apple-ios.
  private_lane :build_signed_ipa do
    require "base64"
    require "fileutils"
    unless File.directory?("../native/crates/lighthouse-desktop/gen/apple")
      UI.user_error!("gen/apple is missing — run the mobile-bootstrap ios-init task first (§2.2).")
    end
    setup_ci if ENV["CI"] # temp keychain so the match cert is usable headless
    key = asc_api_key
    match(type: "appstore", api_key: key, readonly: true)
    # The CLI wants the raw .p8 on disk (0600, deleted after).
    key_path = File.expand_path("../build/asc_key.p8")
    FileUtils.mkdir_p(File.dirname(key_path))
    File.write(key_path, Base64.decode64(ENV.fetch("APP_STORE_CONNECT_KEY_P8")))
    File.chmod(0o600, key_path)
    begin
      sh(
        {
          "APPLE_API_KEY" => ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
          "APPLE_API_ISSUER" => ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
          "APPLE_API_KEY_PATH" => key_path,
          "APPLE_DEVELOPMENT_TEAM" => ENV.fetch("APPLE_TEAM_ID"),
        },
        "cd .. && npm run -- tauri ios build --export-method app-store-connect",
      )
    ensure
      File.delete(key_path) if File.exist?(key_path)
    end
    ipa = Dir["../native/crates/lighthouse-desktop/gen/apple/build/**/*.ipa"]
      .max_by { |f| File.mtime(f) }
    UI.user_error!("tauri ios build produced no .ipa under gen/apple/build/") unless ipa
    FileUtils.mkdir_p("../build/ios")
    FileUtils.cp(ipa, "../build/ios/Lighthouse.ipa")
    lane_context[SharedValues::IPA_OUTPUT_PATH] = File.expand_path("../build/ios/Lighthouse.ipa")
    key
  end

  # Prove the signed .ipa builds — no upload. Safe before the App Store
  # Connect app record exists; the artifact lands in build/ios/.
  lane :build_ipa do
    build_signed_ipa
  end

  # TestFlight: signed build + upload. Requires the App Store Connect app
  # record for app.lhvault to exist (one-time manual step — the API can't
  # create app records; see docs/mobile-signing.md).
  lane :beta do
    key = build_signed_ipa
    upload_to_testflight(
      api_key: key,
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_waiting_for_build_processing: true,
    )
  end
end

platform :android do
  # Play internal-testing upload. Requires gen/android (tauri android init) +
  # the upload keystore + Play service-account secrets (docs/mobile-signing.md).
  lane :beta do
    unless File.directory?("../gen/android")
      UI.user_error!("gen/android is missing — run `tauri android init` first (§2.2).")
    end
    sh("cd .. && npm run tauri android build -- --aab")
    upload_to_play_store(
      package_name: "app.lhvault",
      track: "internal",
      json_key_data: ENV.fetch("PLAY_SERVICE_ACCOUNT_JSON"),
      aab: Dir["../gen/android/**/*.aab"].max_by { |f| File.mtime(f) },
    )
  end
end
