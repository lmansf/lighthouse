{
  "name": "rag-vault",
  "version": "0.1.0",
  "private": true,
  "description": "Lighthouse — a local-first RAG vault for your documents.",
  "author": "Lighthouse",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "icons": "npm install --no-save sharp@^0.33.5 png-to-ico@^2.1.8 && node scripts/gen-icons.mjs",
    "electron": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.lighthouse.app",
    "productName": "Lighthouse",
    "executableName": "Lighthouse",
    "icon": "build/icon.png",
    "asar": false,
    "files": [
      "**/*",
      "!**/.next/cache/**/*",
      "!**/release/**/*",
      "!**/*.map",
      "!**/Lighthouse.cmd",
      "!**/Lighthouse.command",
      "!**/install.sh"
    ],
    "extraMetadata": { "main": "electron/main.js" },
    "directories": { "output": "release" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg", "category": "public.app-category.productivity" },
    "linux": { "target": "AppImage", "category": "Utility" },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lighthouse",
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "uninstallDisplayName": "Lighthouse"
    }
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-icons": "^2.0.245",
    "next": "^15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "5.7.3"
  }
}
