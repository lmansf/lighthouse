# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/

# production
# build/ is electron-builder's resources dir — ignore its contents but keep the
# committed icon sources the desktop build needs.
/build/*
!/build/icon.svg
!/build/icon.png
!/build/icon.ico
!/build/tray.svg
!/build/installer.nsh
!/build/installerSidebar.bmp
!/build/uninstallerSidebar.bmp
!/build/entitlements.mac.plist
!/build/notarize.cjs

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vault local state: inclusion flags, profile + API key, indexes (never commit)
vault/.rag-vault/
# user-added documents (sample docs under vault/ are tracked; uncomment to keep
# your own vault private if you store documents inside the repo)
# /vault/

# typescript
*.tsbuildinfo
next-env.d.ts

# electron-builder output (packaged app + installer) — large build artifacts.
/release/

# Bundled local model assets (llama-server binary + .gguf weights) — large and
# licensed separately; fetched at build time by `npm run fetch:model`.
/resources/llm/*
!/resources/llm/.gitkeep

# Bundled local TTS assets (Piper binary + neural voice) — same deal: large and
# licensed separately, fetched at build time by `npm run fetch:model`.
/resources/tts/*
!/resources/tts/.gitkeep

# Bundled embedding model (nomic-embed GGUF, B2 hybrid search) — fetched at
# build time by `npm run fetch:model`.
/resources/embed/*
!/resources/embed/.gitkeep

# Lavish review artifacts (local tooling)
.lavish/

# Rust native workspace
native/target/

# Tauri UI bundle (generated by scripts/build-ui-static.mjs)
native/crates/lighthouse-desktop/ui-dist/
# Next static-export scratch
.next-export/
.api-excluded-during-export/
out/

# Tauri codegen (regenerated by tauri-build)
native/crates/lighthouse-desktop/gen/
# Stray artifact dir from experiment.assign test (hardcoded Windows path)
C:/
native/crates/lighthouse-core/vault/
# Perf-audit scratch notes (analysis working files, not shipped)
scratch-perf/
