{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window and the vault-explorer satellite: core APIs plus the dialog/opener/notification plugins (portable — these exist on every platform).",
  "windows": [
    "main",
    "explorer"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:webview:allow-internal-toggle-devtools",
    "dialog:default",
    "opener:default",
    "opener:allow-open-url",
    "notification:default"
  ]
}
