# Copy to .env.local and fill in as needed. .env.local is gitignored AND is
# excluded from the packaged installer — it is for local development only.

# Optional: where your documents live. Defaults to ./vault inside the repo.
# Point it anywhere on disk for private docs, e.g. /home/you/Documents/vault
# VAULT_DIR=./vault

# Optional: Anthropic API key for synthesized chat answers. If unset, the app
# falls back to local extractive answers (no network). You can also set this
# from the onboarding UI, which stores it in vault/.rag-vault/profile.json.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: local model (the "Local model (private)" provider). Answers entirely
# on-device against a local OpenAI chat-completions compatible server — no key,
# no network. The desktop app bundles llama-server and auto-launches it on :8080
# once you install the private model (a one-time, opt-in ~4.2 GB download from the
# model picker); otherwise point these at your own Ollama or LM Studio instance.
# LIGHTHOUSE_LOCAL_LLM_URL=http://127.0.0.1:8080/v1/chat/completions
# Required only for servers that need a named model (Ollama, LM Studio); set it
# to the model you pulled, e.g. llama3.2. llama-server ignores it.
# LIGHTHOUSE_LOCAL_LLM_MODEL=llama3.2
