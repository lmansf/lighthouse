# Copy to .env.local and fill in as needed. .env.local is gitignored.

# Optional: where your documents live. Defaults to ./vault inside the repo.
# Point it anywhere on disk for private docs, e.g. /home/you/Documents/vault
# VAULT_DIR=./vault

# Optional: Anthropic API key for synthesized chat answers. If unset, the app
# falls back to local extractive answers (no network). You can also set this
# from the onboarding UI, which stores it in vault/.rag-vault/profile.json.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Supabase for the welcome-registration form + trial licensing.
# Create/extend the table with the SQL in docs/registration.md, then set:
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_ANON_KEY=<anon key — welcome-form "configured" check>
# SUPABASE_REGISTRATIONS_TABLE=registrations

# Trial licensing. When SUPABASE_URL is set (or LICENSE_ENFORCE=1), each
# registration mints a 14-day trial; on expiry the vault is RESET and the user
# must start a new trial. The server reads/extends trials with the SERVICE-ROLE
# key (never exposed to the client), and encrypts the license key with
# LICENSE_SECRET — set a strong value in production.
# SUPABASE_SERVICE_ROLE_KEY=<service-role key — server-side only>
# LICENSE_SECRET=<long random string>
# LICENSE_ENFORCE=1   # force trial enforcement even without Supabase (local trials)
