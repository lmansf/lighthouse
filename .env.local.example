# Copy to .env.local and fill in as needed. .env.local is gitignored.

# Optional: where your documents live. Defaults to ./vault inside the repo.
# Point it anywhere on disk for private docs, e.g. /home/you/Documents/vault
# VAULT_DIR=./vault

# Optional: Anthropic API key for synthesized chat answers. If unset, the app
# falls back to local extractive answers (no network). You can also set this
# from the onboarding UI, which stores it in vault/.rag-vault/profile.json.
# ANTHROPIC_API_KEY=sk-ant-...
