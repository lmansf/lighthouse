# Copy to .env.local and fill in as needed. .env.local is gitignored AND is
# excluded from the packaged installer — it is for local development only.

# Optional: where your documents live. Defaults to ./vault inside the repo.
# Point it anywhere on disk for private docs, e.g. /home/you/Documents/vault
# VAULT_DIR=./vault

# Optional: Anthropic API key for synthesized chat answers. If unset, the app
# falls back to local extractive answers (no network). You can also set this
# from the onboarding UI, which stores it in vault/.rag-vault/profile.json.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: local model (the "Local model (private)" provider). Answers entirely
# on-device against a local OpenAI chat-completions compatible server — no key,
# no network. The desktop app auto-launches a bundled llama-server on :8080 when
# one is packaged under resources/llm; otherwise point these at your own Ollama
# or LM Studio instance.
# LIGHTHOUSE_LOCAL_LLM_URL=http://127.0.0.1:8080/v1/chat/completions
# Required only for servers that need a named model (Ollama, LM Studio); set it
# to the model you pulled, e.g. llama3.2. llama-server ignores it.
# LIGHTHOUSE_LOCAL_LLM_MODEL=llama3.2

# ─── Trial licensing ────────────────────────────────────────────────────────
# Secrets (the Supabase service-role key and LICENSE_SECRET) live ONLY in the
# hosted Supabase Edge Function — never in the desktop app. See the deploy steps
# in docs/registration.md. The shipped app reads only PUBLIC config, which lives
# in the committed .env.production:
#
#   LICENSE_API_URL      https://<project>.supabase.co/functions/v1/license
#   SUPABASE_ANON_KEY    public anon key (authorizes the function call)
#   CHECKOUT_API_URL     public create-checkout function URL for the $14.99/mo plan
#   PAID_ENABLED         1 to show the Subscribe UI; 0 (default) shows "Get notified"
#
# To point your local dev build at the hosted function, copy those into
# .env.local (they override .env.production). The Stripe SECRET key and webhook
# secret live ONLY in the stripe-webhook Edge Function — never in the app.

# ─── Local-dev trial (no hosted function) ───────────────────────────────────
# Leave LICENSE_API_URL unset and enable a self-contained local trial that uses
# local crypto. For development only — no Supabase, no network.
# LICENSE_ENFORCE=1
# LICENSE_SECRET=<long random string — encrypts the local license key>
